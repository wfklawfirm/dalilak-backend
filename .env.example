# ═══════════════════════════════════════════════════════════════
# Dalilak AI — Backend Environment Variables
# Copy to .env and fill in real values. Never commit .env
# ═══════════════════════════════════════════════════════════════

# ── Environment ─────────────────────────────────────────────────
ENVIRONMENT=production
# development | production

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_URL=https://xxxx.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ── JWT Auth ────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET=change-this-to-another-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_EMAIL=admin@dalilak.ai

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://dalilak-frontend.vercel.app,https://dalilak.ai

# ── Database ────────────────────────────────────────────────────
# SQLite (default, Render free tier — data lost on restart):
# DATABASE_URL=sqlite:///./dalilak.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/dalilak

# ── Frontend URL (used in emails) ──────────────────────────────
FRONTEND_URL=https://dalilak-frontend.vercel.app

# ── Email (optional — for forgot-password emails) ───────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@dalilak.ai
# SMTP_PASS=your-app-password
# FROM_EMAIL=noreply@dalilak.ai
